CREATE OR REPLACE VIEW V_QRY_MASTERBREAKS_PARENT_AMTS
AS
SELECT

    VMPB.AGENT_CODE,

    VMPB.LOCAL_ACC_NO,

    VMPB.STOCK_CODE,

    MAX(VMPB.STMT_DATE) AS MAXOFSTATEMENT,

    MAX(VMPB.AMOUNT_6) AS MAXOFAMOUNT6,

    MAX(VMPB.AMOUNT_5) AS MAXOFPRICE,

    MIN(VMPB.STRING_27) AS FIRSTOFSECID,

    MIN(VMPB.STRING_28) AS FIRSTOFSECNAME,

    MIN(VMPB.STRING_14) AS FIRSTOFSTRING14,

    MIN(VMPB.STRING_21) AS FIRSTOFSTRING21,

    MAX(VMPB.STRING_21) AS LASTOFSTRING21,

    MIN(VMPB.STRING_29) AS FIRSTOFBBHACCTNAME,

    MIN(VMPB.STRING_13) AS FIRSTOFFREQ

FROM
    V_TBL_MASTERPOSITIONBREAKS VMPB

GROUP BY

    VMPB.AGENT_CODE,

    VMPB.LOCAL_ACC_NO,

    VMPB.STOCK_CODE;
	
	===============================================================
	
	
	SELECT
    TBMH.REASON_CATEGORY AS DEPT,

    TBMH.CODE_NAME || ' - ' || TBMH.REASON_NAME AS TYPE,

    TBMH.STMT_DATE AS "PARENT BREAK DATE",

    PAHEDGE.MAXOFSTATEMENT AS "STATEMENT DATE(NEW)",

    TRUNC(SYSDATE) - TRUNC(TBMH.SYS_ENTRY_DATE) AS DISCVAGE,

    ROUND(TRUNC(SYSDATE) - TRUNC(TBMH.STMT_DATE)) AS "RECON AGE",

    PAHEDGE.FIRSTOFSECID AS BBHNUM,

    NVL(TBMH.STOCK_CODE,'N/A') AS ISIN,

    PAHEDGE.FIRSTOFSECNAME AS "ASSET DESCRIPTION",

    CASE
        WHEN TBMH.STRING_14 IS NOT NULL
         AND TRIM(TBMH.STRING_14) <> ''
        THEN TRIM(TBMH.STRING_14)
        WHEN SUBSTR(TBMH.LOCAL_ACC_NO,8,1)='-'
        THEN SUBSTR(TBMH.LOCAL_ACC_NO,1,7)
        ELSE 'OMNIBUS'
    END AS BBHACCTNUM,

    PAHEDGE.FIRSTOFBBHACCTNAME AS BBHACCTNAME,

    PAHEDGE.FIRSTOFSTRING21 AS BBHEXTACTNUM,

    PAHEDGE.LASTOFSTRING21 AS FUNDEXTACCTNUM,

    TO_CHAR(
        PAHEDGE.MAXOFBBHAMOUNT,
        'FM999G999G999G999G990D000000'
    ) AS BBHAMOUNT,

    TO_CHAR(
        PAHEDGE.MAXOFNSCCAMOUNT,
        'FM999G999G999G999G990D000000'
    ) AS FUNDAMOUNT,

    TO_CHAR(
        ABS(PAHEDGE.MAXOFBBHAMOUNT - PAHEDGE.MAXOFNSCCAMOUNT),
        'FM999G999G999G999G990D000000'
    ) AS BREAK,

    CASE
        WHEN TBMH.LS_TYPE IN (9106,9129)
        THEN TBMH.AMOUNT_6
        ELSE -TBMH.AMOUNT_6
    END AS CHILDBREAK,

    CASE
        WHEN TBMH.LS_TYPE IN (9106,9129)
        THEN TBMH.AMOUNT_6
        ELSE -TBMH.AMOUNT_6
    END * NVL(PAHEDGE.MAXOFPRICE,0) AS EXPOSURE,

    TBMH.STRING_6 AS "BREAK DESCRIPTION",

    TBMH.NOTE AS COMMENTS,

    CASE
        WHEN TBMH.AGENT_CODE LIKE '%MUTUAL FUNDS - NSCC TRANS POS%'
        THEN 'NSCC'
        WHEN TBMH.AGENT_CODE LIKE '%MUTUAL FUNDS - MONTHLY POSITIONS%'
        THEN 'MONTHLY'
        WHEN TBMH.AGENT_CODE LIKE '%MUTUAL FUNDS - SWIFT DAILY POSITIONS%'
        THEN 'SWIFTDAILY'
        WHEN TBMH.AGENT_CODE LIKE '%MUTUAL FUNDS - HEDGE%'
        THEN 'HEDGE'
    END AS SOURCEDB

FROM
    V_TBL_BREAKDETAILS_MONTHLYANDHEDGE TBMH

INNER JOIN
    V_QRY_MASTERBREAKS_PARENT_AMTS PAHEDGE
ON  PAHEDGE.LOCAL_ACC_NO = TBMH.LOCAL_ACC_NO
AND PAHEDGE.STOCK_CODE   = TBMH.STOCK_CODE

WHERE
    UPPER(TBMH.REASON_CATEGORY) = 'CA-INCOME'
AND CASE
        WHEN TBMH.AGENT_CODE LIKE '%MUTUAL FUNDS - NSCC TRANS POS%'
        THEN 'NSCC'
        WHEN TBMH.AGENT_CODE LIKE '%MUTUAL FUNDS - MONTHLY POSITIONS%'
        THEN 'MONTHLY'
        WHEN TBMH.AGENT_CODE LIKE '%MUTUAL FUNDS - SWIFT DAILY POSITIONS%'
        THEN 'SWIFTDAILY'
        WHEN TBMH.AGENT_CODE LIKE '%MUTUAL FUNDS - HEDGE%'
        THEN 'HEDGE'
    END IN ('SWIFTDAILY','NSCC','HEDGE','MONTHLY')
AND UPPER(TBMH.REASON_NAME) <> 'RESOLVED'
AND ABS(
        (
            CASE
                WHEN TBMH.LS_TYPE IN (9106,9129)
                THEN TBMH.AMOUNT_6
                ELSE -TBMH.AMOUNT_6
            END
        ) * NVL(PAHEDGE.MAXOFPRICE,0)
    ) > 50000

ORDER BY
    TBMH.REASON_CATEGORY,
    TYPE,
    BBHNUM;
