SELECT
    TBMSEB.STOCK_CODE AS ISIN,
    TBMSEB.SebAcctNum,

    MAX(TBMSEB.SecID)
        KEEP (DENSE_RANK FIRST ORDER BY TBMSEB.SecID) AS MinOfSecID,

    MAX(TBMSEB.SecName)
        KEEP (DENSE_RANK FIRST ORDER BY TBMSEB.SecID) AS FirstOfSecName,

    MAX(TBMSEB.BbhAmount) AS MaxOfBbhAmount,

    MAX(TBMSEB.SebAmount) AS MaxOfSebAmount,

    MAX(TBMSEB.Statement) AS MaxOfStatement,

    MAX(TBMSEB.BbhAcctNum) AS MaxOfBbhAcctNum,

    MAX(TBMSEB.NAV) AS MaxOfNAV,

    MAX(TBMSEB.Currency)
        KEEP (DENSE_RANK FIRST ORDER BY TBMSEB.SecID) AS FirstOfCurrency

FROM
    tbl_MasterPositionBreaks_SEB TBMSEB

GROUP BY
    TBMSEB.STOCK_CODE,
    TBMSEB.SebAcctNum

ORDER BY
    MAX(TBMSEB.SecID)
        KEEP (DENSE_RANK FIRST ORDER BY TBMSEB.SecID);
