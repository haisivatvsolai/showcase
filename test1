CREATE OR REPLACE VIEW V_TBL_BREAKDETAILS_MONTHLYANDHEDGE
AS
SELECT
    /* BANK */
    B.LOCAL_ACC_NO,
    B.AGENT_CODE,
    B.CORR_ACC_NO,

    /* ITEM */
    I.ITEM_ID,
    I.STOCK_ID,
    I.BRAN_CODE,
    I.REASON_TYPE_ID,
    I.NOTE_ID,

    I.STRING_6,
    I.STRING_14,
    I.STRING_21,

    I.REFERENCE,

    I.AMOUNT_6,
    I.SYS_ENTRY_DATE,
    I.STMT_DATE,

    I.LS_TYPE,
    I.FLAG_2,

    /* STOCK */
    S.STOCK_CODE,

    /* DEPARTMENT */
    D.CODE_NAME,

    /* REASON */
    RT.NAME AS REASON_NAME,

    RC.NAME AS REASON_CATEGORY,

    /* NOTE */
    N.NOTE

FROM BANK B

INNER JOIN ITEM I
    ON B.CORR_ACC_NO = I.CORR_ACC_NO

LEFT JOIN STCK S
    ON I.STOCK_ID = S.STOCK_ID

LEFT JOIN DCOD D
    ON I.BRAN_CODE = D.CODEC

LEFT JOIN TLM_REF_REASON_TYPE RT
    ON I.REASON_TYPE_ID = RT.REASON_TYPE_ID

LEFT JOIN TLM_REF_REASON_CATEGORY RC
    ON RT.REASON_CATEGORY_ID = RC.REASON_CATEGORY_ID

LEFT JOIN TLM_BDR_NOTE N
    ON I.NOTE_ID = N.ID

WHERE
(
       B.AGENT_CODE LIKE '%MUTUAL FUNDS - NSCC TRANS POS%'
    OR B.AGENT_CODE LIKE '%MUTUAL FUNDS - MONTHLY POSITIONS%'
    OR B.AGENT_CODE LIKE '%MUTUAL FUNDS - SWIFT DAILY POSITIONS%'
    OR B.AGENT_CODE LIKE '%MUTUAL FUNDS - HEDGE%'
)
AND I.LS_TYPE NOT IN (9030,9099)
AND NVL(I.FLAG_2,0)=0;

