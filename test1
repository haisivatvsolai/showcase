CREATE OR REPLACE VIEW V_TBL_MASTERPOSITIONBREAKS
AS
SELECT
    /* BANK */
    B.AGENT_CODE,
    B.LOCAL_ACC_NO,
    B.CORR_ACC_NO,

    /* ITEM */
    I.ITEM_ID,
    I.STOCK_ID,
    I.LS_TYPE,
    I.FLAG_2,

    I.STRING_13,
    I.STRING_14,
    I.STRING_21,
    I.STRING_27,
    I.STRING_28,
    I.STRING_29,

    I.AMOUNT_5,
    I.AMOUNT_6,

    I.STMT_DATE,
    I.SYS_ENTRY_DATE,

    /* STOCK */
    S.STOCK_CODE

FROM BANK B

INNER JOIN ITEM I
    ON B.CORR_ACC_NO = I.CORR_ACC_NO

LEFT JOIN STCK S
    ON I.STOCK_ID = S.STOCK_ID

WHERE
(
       B.AGENT_CODE LIKE '%MUTUAL FUNDS - NSCC TRANS POS%'
    OR B.AGENT_CODE LIKE '%MUTUAL FUNDS - MONTHLY POSITIONS%'
    OR B.AGENT_CODE LIKE '%MUTUAL FUNDS - SWIFT DAILY POSITIONS%'
    OR B.AGENT_CODE LIKE '%MUTUAL FUNDS - HEDGE%'
)
AND I.LS_TYPE IN (9030,9099)
AND NVL(I.FLAG_2,0)=0;

